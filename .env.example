# ─── Environment Setup Instructions ──────────────────────────────────
# 1. Copy this file and rename it to ".env"
# 2. Fill in the placeholder values below with your actual credentials
# 3. DO NOT commit the real ".env" file to version control

# ─── Server ──────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grihastha
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ─── Client URLs ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5174

# ─── Nodemailer (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# ─── Cloudinary ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ─── Vite Client (VITE_ prefix required) ────────────────────────────
VITE_API_URL=http://localhost:5001/v1
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key

# ─── Khalti Payment Gateway ────────────────────────────────────────
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key
VITE_KHALTI_PUBLIC_KEY=your_khalti_public_key

# ─── Firebase ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin-key.json
